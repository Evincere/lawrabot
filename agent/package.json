{
  "name": "templateclaw",
  "version": "0.1.0",
  "description": "Reusable AI agent template — specialize with prompts, tools, and config",
  "type": "module",
  "private": true,
  "bin": {
    "templateclaw": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "oxlint src/"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "commander": "^14.0.0",
    "eventsource": "^4.1.0",
    "express": "^5.1.0",
    "grammy": "^1.35.0",
    "jiti": "^2.4.2",
    "json5": "^2.2.3",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.16.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/pdfkit": "^0.13.9",
    "@types/qrcode-terminal": "^0.12.2",
    "tsdown": "^0.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
